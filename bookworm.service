[Unit]
Description=Bookworm Audiobook Reader
After=network.target

[Service]
Type=simple
User=spoder
WorkingDirectory=/home/spoder/Projects/bookworm
ExecStart=/home/spoder/Projects/bookworm/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
